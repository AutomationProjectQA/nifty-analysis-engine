# Nifty Analysis Engine — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# Load locally with:  ./run-local.sh   (or: set -a; source .env; set +a)
# In production, point systemd at it:  EnvironmentFile=/etc/nifty/nifty.env

# --- Database (optional; defaults to local Postgres) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nifty
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- Redis (optional; defaults to localhost) ---
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# --- Telegram alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Gemini (LLM thesis generation) ---
GEMINI_API_KEY=

# --- Angel One SmartAPI (market data + order execution) ---
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_CODE=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_KEY=
